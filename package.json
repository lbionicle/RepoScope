{
  "name": "reposcope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "graphql:codegen": "graphql-codegen --config codegen.ts",
    "postinstall": "husky"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@apollo/client-integration-nextjs": "^0.14.5",
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "16",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rxjs": "^7.8.2",
    "server-only": "^0.0.1",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typed-document-node": "^7.0.3",
    "@graphql-codegen/typescript-operations": "^6.0.4",
    "@next/env": "16.2.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.8.4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,mdx,yml,yaml,css,html,graphql,gql}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
